# {{ ansible_managed }}
[Unit]
Description=step-ca (Homelab internal certificate authority)
Documentation=https://smallstep.com/docs/step-ca
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ step_ca_user }}
Group={{ step_ca_user }}
Environment=STEPPATH={{ step_ca_path }}
ExecStart=/usr/bin/step-ca {{ step_ca_path }}/config/ca.json --password-file {{ step_ca_path }}/password.txt
Restart=on-failure
RestartSec=5

; 非rootユーザーで:443をbindするため
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ProtectSystem=full
ProtectHome=true
PrivateTmp=true
; 発行DB(STEPPATH/db)への書き込みを許可する
ReadWritePaths={{ step_ca_path }}

[Install]
WantedBy=multi-user.target
