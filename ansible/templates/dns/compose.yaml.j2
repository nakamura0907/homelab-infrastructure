# {{ ansible_managed }}
services:
  unbound:
    image: {{ unbound_image }}
    container_name: unbound
    hostname: unbound
    restart: unless-stopped
    volumes:
      # 追加設定（home.arpa を insecure 扱いにする防御的設定）
      - ./unbound/conf.d:/opt/unbound/etc/unbound/unbound.conf.d:ro
    networks:
      dns_net:
        ipv4_address: {{ dns_unbound_ip }}

  pihole:
    image: {{ pihole_image }}
    container_name: pihole
    hostname: pihole
    restart: unless-stopped
    depends_on:
      - unbound
    # 管理UI(:80)はホストへ公開せず、Caddy(:443)がTLS終端して転送する
    ports:
      - "53:53/tcp"
      - "53:53/udp"
    environment:
      TZ: "{{ dns_timezone }}"
      WEBPASSWORD: "{{ dns_web_password }}"
      FTLCONF_LOCAL_IPV4: "{{ dns_host_ip }}"
      # 上流は同一ネットワーク上の Unbound（再帰リゾルバ）
      PIHOLE_DNS_: "{{ dns_unbound_ip }}#53"
      # DNSSEC 検証は Unbound 側で行うため Pi-hole 側は無効化
      DNSSEC: "false"
    volumes:
      - ./pihole/etc-pihole:/etc/pihole
      - ./pihole/etc-dnsmasq.d:/etc/dnsmasq.d
    networks:
      dns_net:
        ipv4_address: {{ dns_pihole_ip }}

  # Pi-hole管理UIのTLS終端。証明書は内部CA(step-ca)からACME(HTTP-01)で自動取得・更新
  caddy:
    image: {{ caddy_image }}
    container_name: caddy
    restart: unless-stopped
    depends_on:
      - pihole
    ports:
      - "80:80/tcp"
      - "443:443/tcp"
    # ACMEサーバーの名前解決をDNS(自分自身)の稼働状態に依存させない
    extra_hosts:
      - "ca.home.arpa:{{ pki_host_ip }}"
    volumes:
      - ./caddy/Caddyfile:/etc/caddy/Caddyfile:ro
      - ./caddy/data:/data
      - ./caddy/config:/config
      # site_pki.ymlが配布するルートCA(ACMEサーバーへのTLS接続の信頼に必要)
      - /usr/local/share/ca-certificates/homelab-root-ca.crt:/etc/caddy/root_ca.crt:ro
    networks:
      dns_net:
        ipv4_address: {{ dns_caddy_ip }}

networks:
  dns_net:
    driver: bridge
    ipam:
      config:
        - subnet: {{ dns_internal_subnet }}
